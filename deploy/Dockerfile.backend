FROM golang:1.24-alpine AS builder

WORKDIR /app

ARG BUILD_VERSION=dev

# Install build dependencies
RUN apk add --no-cache gcc musl-dev git sqlite-dev

# Copy go mod files
COPY go.mod ./
RUN go mod download || true

# Copy source code
COPY . .

# Generate go.sum and download dependencies
RUN go mod tidy

# Build with version info via ldflags
RUN CGO_ENABLED=1 GOOS=linux go build -ldflags "-X main.Version=${BUILD_VERSION} -X main.BuildTime=$(date -u +%Y-%m-%dT%H:%M:%SZ)" -o /clarin ./cmd/server

# Runtime stage
FROM alpine:3.19

WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata sqlite-libs

# Copy binary
COPY --from=builder /clarin /app/clarin

# Copy changelog for API serving
COPY --from=builder /app/CHANGELOG.md /app/CHANGELOG.md

# Create sessions directory
RUN mkdir -p /app/sessions

# Expose ports
EXPOSE 8080
EXPOSE 8081

# Run
CMD ["/app/clarin"]
