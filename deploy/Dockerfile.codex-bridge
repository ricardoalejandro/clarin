FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=production
ENV CODEX_HOME=/var/lib/codex

RUN apk add --no-cache ca-certificates git \
  && npm install -g @openai/codex@0.141.0

COPY package.json ./
COPY server.js ./

RUN mkdir -p /var/lib/codex /tmp/eros-codex-workspace

EXPOSE 8787

CMD ["node", "server.js"]
